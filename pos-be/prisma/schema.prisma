generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  CASHIER
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELLED
  COMPLETED
  RETURNED
}

enum PaymentType {
  CASH
  QRIS
  QRIS_MANUAL
  TRANSFER
}

enum StockMovementType {
  IN
  OUT
}

enum StockMovementSource {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum OrderType {
  DINE_IN
  TAKE_AWAY
  PRE_ORDER
}

model User {
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar(255)
  email    String  @unique @db.VarChar(255)
  password String  @db.VarChar(255)
  role     Role    @default(CASHIER)
  imageUrl String? @map("image_url") @db.Text
  isActive Boolean @default(true) @map("is_active")

  otpCode      String?   @map("otp_code") @db.VarChar(6)
  otpExpiresAt DateTime? @map("otp_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions      Transaction[]
  savedTransactions SavedTransaction[]

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  androidId   Int?      @unique @map("android_id")
  name        String    @db.VarChar(100)
  imageUrl    String?   @map("image_url") @db.Text
  displayType String    @default("normal") @map("display_type")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@map("categories")
}

model Product {
  id               Int     @id @default(autoincrement())
  androidId        Int?    @unique @map("android_id")
  categoryId       Int     @map("category_id")
  sku              String  @unique @db.VarChar(50)
  name             String  @db.VarChar(255)
  imageUrl         String? @map("image_url") @db.Text
  barcode          String? @db.VarChar(100)
  displayType      String  @default("normal") @map("display_type")
  price            Decimal @db.Decimal(15, 2)
  costPrice        Decimal @default(0) @map("cost_price") @db.Decimal(15, 2)
  stock            Int     @default(0)
  minStock         Int     @default(0) @map("min_stock")
  isActive         Boolean @default(true) @map("is_active")
  isUnlimitedStock Boolean @default(false) @map("is_unlimited_stock")
  enableCostPrice  Boolean @default(false) @map("enable_cost_price")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  category          Category           @relation(fields: [categoryId], references: [id])
  transactionItems  TransactionItem[]
  stockMovements    StockMovement[]
  stockReceiptItems StockReceiptItem[]
  addons            ProductAddon[]
  packageItems      PackageItem[]

  @@map("products")
}

model Customer {
  id              Int           @id @default(autoincrement())
  androidId       Int?          @unique @map("android_id")
  memberId        String        @unique @map("member_id") @db.VarChar(20)
  name            String        @db.VarChar(255)
  phone           String?       @unique @db.VarChar(20)
  email           String?       @db.VarChar(255)
  imageUrl        String?       @map("image_url") @db.Text
  displayType     String        @default("normal") @map("display_type")
  loyaltyDiscount Decimal       @default(0) @map("loyalty_discount") @db.Decimal(5, 2)
  points          Int           @default(0) @map("points")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  transactions    Transaction[]

  @@map("customers")
}

model Transaction {
  id                Int               @id @default(autoincrement())
  androidId         String?           @unique @map("android_id") @db.VarChar(100)
  userId            Int               @map("user_id")
  customerId        Int?              @map("customer_id")
  customerName      String?           @map("customer_name") @db.VarChar(255)
  invoiceNumber     String            @unique @map("invoice_number") @db.VarChar(50)
  subTotal          Decimal           @default(0) @map("sub_total") @db.Decimal(15, 2)
  taxAmount         Decimal           @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount    Decimal           @default(0) @map("discount_amount") @db.Decimal(15, 2)
  grandTotal        Decimal           @map("grand_total") @db.Decimal(15, 2)
  cashAmount        Decimal?          @map("cash_amount") @db.Decimal(15, 2)
  changeAmount      Decimal?          @map("change_amount") @db.Decimal(15, 2)
  status            TransactionStatus @default(PENDING)
  orderType         OrderType         @default(DINE_IN) @map("order_type")
  tableNumber       String?           @map("table_number") @db.VarChar(20)
  note              String?           @db.Text
  preOrderDate      DateTime?         @map("pre_order_date")
  preOrderConfirmed Boolean           @default(false) @map("pre_order_confirmed")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  user              User              @relation(fields: [userId], references: [id])
  customer          Customer?         @relation(fields: [customerId], references: [id])
  items             TransactionItem[]
  payments          Payment[]

  @@map("transactions")
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  transactionId Int         @map("transaction_id")
  productId     Int         @map("product_id")
  qty           Int
  price         Decimal     @db.Decimal(15, 2)
  costPrice     Decimal     @default(0) @map("cost_price") @db.Decimal(15, 2)
  notes         String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@map("transaction_items")
}

model Payment {
  id            Int         @id @default(autoincrement())
  transactionId Int         @map("transaction_id")
  paymentType   PaymentType @map("payment_type")
  amount        Decimal     @db.Decimal(15, 2)
  referenceId   String?     @map("reference_id") @db.VarChar(255)
  paymentStatus String?     @map("payment_status") @db.VarChar(50)
  createdAt     DateTime    @default(now()) @map("created_at")
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@map("payments")
}

model StockMovement {
  id          Int                 @id @default(autoincrement())
  productId   Int                 @map("product_id")
  type        StockMovementType
  qty         Int
  source      StockMovementSource
  description String?             @db.Text
  createdAt   DateTime            @default(now()) @map("created_at")
  product     Product             @relation(fields: [productId], references: [id])

  @@map("stock_movements")
}

model StoreSetting {
  id                    Int      @id @default(autoincrement())
  storeName             String   @default("My POS Store") @map("store_name")
  logoUrl               String?  @map("logo_url") @db.Text
  address               String?  @db.Text
  phone                 String?  @db.VarChar(20)
  email                 String?  @db.VarChar(255)
  website               String?  @db.VarChar(255)
  enableCash            Boolean  @default(true) @map("enable_cash")
  enableQris            Boolean  @default(false) @map("enable_qris")
  enableDebit           Boolean  @default(false) @map("enable_debit")
  taxRate               Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  serviceCharge         Decimal  @default(0) @map("service_charge") @db.Decimal(5, 2)
  autoPrintReceipt      Boolean  @default(true) @map("auto_print_receipt")
  receiptFooter         String?  @map("receipt_footer") @db.Text
  enablePreOrder        Boolean  @default(false) @map("enable_pre_order")
  enableShift           Boolean  @default(true) @map("enable_shift")
  enableDineTable       Boolean  @default(false) @map("enable_dine_table")
  takeawayOptions       String?  @map("takeaway_options") @db.Text
  allowNegativeStock    Boolean  @default(false) @map("allow_negative_stock")
  showImages            Boolean  @default(true) @map("show_images")
  theme                 String   @default("light") @db.VarChar(20)
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("store_settings")
}

model LoyaltyConfig {
  id                  Int      @id @default(autoincrement())
  pointMultiplier     Decimal  @default(1) @map("point_multiplier") @db.Decimal(15, 2)
  multiplierAmount    Decimal  @default(10000) @map("multiplier_amount") @db.Decimal(15, 2)
  pointValue          Decimal  @default(100) @map("point_value") @db.Decimal(15, 2)
  minRedemptionPoints Int      @default(10) @map("min_redemption_points")
  isActive            Boolean  @default(true) @map("is_active")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("loyalty_config")
}

// ── NEW MODELS (from PosAndroid) ─────────────────────────────────────────

model Expense {
  id          Int      @id @default(autoincrement())
  description String   @db.Text
  amount      Decimal  @db.Decimal(15, 2)
  category    String   @default("Umum") @db.VarChar(100)
  type        String   @default("EXPENSE") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("expenses")
}

model Shift {
  id          String      @id @default(uuid())
  userId      Int         @map("user_id")
  userName    String      @map("user_name") @db.VarChar(255)
  openedAt    DateTime    @map("opened_at")
  closedAt    DateTime?   @map("closed_at")
  openingCash Decimal     @default(0) @map("opening_cash") @db.Decimal(15, 2)
  closingCash Decimal?    @map("closing_cash") @db.Decimal(15, 2)
  status      ShiftStatus @default(OPEN)

  @@map("shifts")
}

model SavedTransaction {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  cartData  String   @map("cart_data") @db.LongText
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("saved_transactions")
}

model StockReceipt {
  id         String             @id @default(uuid())
  receivedAt DateTime           @map("received_at")
  notes      String?            @db.Text
  createdBy  String?            @map("created_by") @db.VarChar(255)
  items      StockReceiptItem[]

  @@map("stock_receipts")
}

model StockReceiptItem {
  id             Int          @id @default(autoincrement())
  receiptId      String       @map("receipt_id")
  productId      Int          @map("product_id")
  productName    String?      @map("product_name") @db.VarChar(255)
  quantityBefore Int          @default(0) @map("quantity_before")
  quantityAdded  Int          @map("quantity_added")
  costPrice      Decimal      @default(0) @map("cost_price") @db.Decimal(15, 2)
  receipt        StockReceipt @relation(fields: [receiptId], references: [id])
  product        Product      @relation(fields: [productId], references: [id])

  @@map("stock_receipt_items")
}

model ProductAddon {
  id         Int     @id @default(autoincrement())
  androidId  Int?    @unique @map("android_id")
  productId  Int     @map("product_id")
  name       String  @db.VarChar(255)
  price      Decimal @default(0) @db.Decimal(15, 2)
  product    Product @relation(fields: [productId], references: [id])

  @@map("product_addons")
}

model DineTable {
  id         Int      @id @default(autoincrement())
  androidId  Int?     @unique @map("android_id")
  number     String   @unique @db.VarChar(20)
  name       String?  @db.VarChar(100)
  capacity   Int      @default(4)
  status     String   @default("AVAILABLE") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("dine_tables")
}

model Package {
  id          Int           @id @default(autoincrement())
  androidId   Int?          @unique @map("android_id")
  name        String        @db.VarChar(255)
  description String?       @db.Text
  price       Decimal       @db.Decimal(15, 2)
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  items       PackageItem[]

  @@map("packages")
}

model PackageItem {
  id        Int     @id @default(autoincrement())
  packageId Int     @map("package_id")
  productId Int     @map("product_id")
  qty       Int     @default(1)
  
  package   Package @relation(fields: [packageId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("package_items")
}

model Supplier {
  id         Int      @id @default(autoincrement())
  androidId  Int?     @unique @map("android_id")
  name       String   @db.VarChar(255)
  phone      String?  @db.VarChar(20)
  address    String?  @db.Text
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("suppliers")
}
